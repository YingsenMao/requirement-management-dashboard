{
  "color": {
    "surface": {
      "page": {
        "$type": "color",
        "$value": "#f5f7fa"
      },
      "auth": {
        "$type": "color",
        "$value": "#f0f2f5"
      },
      "form": {
        "$type": "color",
        "$value": "#f7f8fa"
      }
    },
    "border": {
      "default": {
        "$type": "color",
        "$value": "#e4e7ed"
      },
      "subtle": {
        "$type": "color",
        "$value": "#e5e6eb"
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#1d2129"
      },
      "secondary": {
        "$type": "color",
        "$value": "#4e5969"
      },
      "muted": {
        "$type": "color",
        "$value": "#86909c"
      }
    },
    "accent": {
      "$type": "color",
      "$value": "#409eff"
    }
  },
  "elevation": {
    "shadow": {
      "card": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "12px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.05)"
        }
      }
    }
  },
  "radius": {
    "lg": {
      "$type": "dimension",
      "$value": "12px"
    },
    "md": {
      "$type": "dimension",
      "$value": "8px"
    }
  },
  "space": {
    "1": {
      "$type": "dimension",
      "$value": "8px"
    },
    "2": {
      "$type": "dimension",
      "$value": "12px"
    },
    "3": {
      "$type": "dimension",
      "$value": "16px"
    },
    "4": {
      "$type": "dimension",
      "$value": "20px"
    },
    "5": {
      "$type": "dimension",
      "$value": "24px"
    },
    "header": {
      "$type": "dimension",
      "$value": "15px"
    }
  },
  "font-size": {
    "brand-icon": {
      "$type": "dimension",
      "$value": "24px"
    },
    "title-page": {
      "$type": "dimension",
      "$value": "20px"
    },
    "section": {
      "$type": "dimension",
      "$value": "16px"
    },
    "accent": {
      "$type": "dimension",
      "$value": "15px"
    }
  },
  "font-weight": {
    "title": {
      "$type": "number",
      "$value": 700
    },
    "semibold": {
      "$type": "number",
      "$value": 600
    }
  },
  "letter-spacing": {
    "tight-title": {
      "$type": "dimension",
      "$value": "0.5px"
    }
  },
  "line-height": {
    "body": {
      "$type": "number",
      "$value": 1.6
    }
  },
  "layout": {
    "viewport-height": {
      "$type": "dimension",
      "$value": "100vh"
    },
    "login-card-width": {
      "$type": "dimension",
      "$value": "400px"
    },
    "login-logo-max": {
      "$type": "dimension",
      "$value": "180px"
    }
  },
  "border-width": {
    "card": {
      "$type": "dimension",
      "$value": "1px"
    }
  },
  "section": {
    "accent-bar-width": {
      "$type": "dimension",
      "$value": "4px"
    }
  },
  "el": {
    "color": {
      "primary": {
        "$type": "color",
        "$value": "#409eff"
      },
      "primary-light-3": {
        "$type": "color",
        "$value": "#79bbff"
      },
      "primary-light-5": {
        "$type": "color",
        "$value": "#a0cfff"
      },
      "primary-light-7": {
        "$type": "color",
        "$value": "#c6e2ff"
      },
      "primary-light-8": {
        "$type": "color",
        "$value": "#d9ecff"
      },
      "primary-light-9": {
        "$type": "color",
        "$value": "#ecf5ff"
      },
      "primary-dark-2": {
        "$type": "color",
        "$value": "#337ecc"
      }
    }
  }
}
